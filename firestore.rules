rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 1. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && (
        (request.auth.token.email != null && request.auth.token.email.lower() == "nguyenhuy.thudaumot@gmail.com") || 
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true)
      );
    }
    function isOfficer() {
      return isSignedIn() && exists(/databases/$(database)/documents/users/$(request.auth.uid)) && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isOfficer == true;
    }

    // Match users
    match /users/{userId} {
      allow get: if isSignedIn() && (request.auth.uid == userId || isAdmin() || isOfficer());
      allow create: if isSignedIn() && request.auth.uid == userId;
      allow update: if (isSignedIn() && request.auth.uid == userId) || isAdmin();
      allow list: if isAdmin() || isOfficer();
      allow delete: if isAdmin();
    }

    // Match campaigns
    match /campaigns/{campaignId} {
      allow read: if true;
      allow create: if isAdmin() || isOfficer();
      allow update: if isAdmin() || isOfficer();
      allow delete: if isAdmin();
    }

    // Match jobs
    match /jobs/{jobId} {
      allow read: if true;
      allow create: if isAdmin() || isOfficer();
      allow update: if isAdmin() || isOfficer();
      allow delete: if isAdmin();
    }

    // Match requests
    match /requests/{requestId} {
      allow read: if true;
      allow create: if true;
      allow update: if true;
      allow delete: if isAdmin();
    }

    // Match donations
    match /donations/{donationId} {
      allow read: if true;
      allow create: if true;
      allow update: if isAdmin() || isOfficer();
      allow delete: if isAdmin();
    }

    // Match facebook news
    match /news_articles/{newsId} {
      allow read: if true;
      allow write: if isAdmin() || isOfficer();
    }

    // Match official partners
    match /official_partners/{partnerId} {
      allow read: if true;
      allow write: if isAdmin() || isOfficer();
    }

    // Match slideshow
    match /slideshow/{slideId} {
      allow read: if true;
      allow write: if isAdmin() || isOfficer();
    }

    // Match events
    match /events/{eventId} {
      allow read: if true;
      allow write: if isAdmin() || isOfficer();
    }

    // Match surveys
    match /surveys/{surveyId} {
      allow read: if true;
      allow write: if isAdmin() || isOfficer();
    }

    // Match volunteer registrations
    match /volunteerRegistrations/{regId} {
      allow read: if isAdmin() || isOfficer();
      allow create: if true; // Allow anyone to register
      allow update: if isAdmin() || isOfficer();
      allow delete: if isAdmin();
    }

    // Match system badges
    match /system_badges/{badgeId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Match policy documents
    match /policyDocuments/{docId} {
      allow read: if true;
      allow write: if isAdmin() || isOfficer();
    }

    // Match party contributions
    match /partyContributions/{contId} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    // Match forum posts
    match /forum_posts/{postId} {
      allow read: if true;
      allow create: if isSignedIn();
      allow update: if isSignedIn() && (resource.data.authorId == request.auth.uid || isAdmin());
      allow delete: if isAdmin();
    }

    // Match brain documents
    match /brain_documents/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Match community_gallery
    match /community_gallery/{imageId} {
      allow read: if true;
      allow create: if isSignedIn();
      allow update, delete: if isAdmin() || (isSignedIn() && resource.data.authorId == request.auth.uid);
    }

    // Match config
    match /config/{configId} {
      allow read: if true;
      allow write: if true;
    }
  }
}
